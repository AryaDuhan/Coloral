# ── Required ──────────────────────────────────────────────────────────────────
# Your bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_token_here

# ── Optional ──────────────────────────────────────────────────────────────────
# Channel ID where daily reminders are sent (right-click channel → Copy ID)
REMINDER_CHANNEL_ID=0

# UTC time for the daily reminder (24-hour format)
# Default: 18:30 UTC = 12:00 AM IST (midnight Indian time)
REMINDER_HOUR=18
REMINDER_MINUTE=30

# ── Coloral Website ──────────────────────────────────────────────────────────
# Shared secret for signing game tokens (generate with: openssl rand -hex 32)
# MUST match the HMAC_SECRET in your Vercel environment variables
HMAC_SECRET=your_random_secret_here

# Your Vercel deployment URL (no https://, e.g. coloral.vercel.app)
WEBSITE_URL=coloral.vercel.app

# Your Discord User ID (bot owner, receives anti-cheat alerts)
BOT_OWNER_ID=782258136303665183

# Discord webhook URL for automated score posting
# Create in: Channel Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxx/yyyy
